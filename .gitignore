# ═══════════════════════════════════════════════════════════════════════════
# ONNX MODEL FILES (LARGE BINARIES - 500MB+ - DOWNLOAD FROM SOURCE)
# ═══════════════════════════════════════════════════════════════════════════

# All ONNX model files
*.onnx
*.onnx.data
*.onnx_data

# Bi-Encoder Models (Sentence Transformer)
Models/Onnx/sentence\ Transformer/sentence_transformer.onnx
Models/Onnx/sentence\ Transformer/model.onnx
Models/Onnx/sentence\ Transformer/tokenizer.json

# Cross-Encoder Models (All variants)
Models/Onnx/CrossEncoder/model.onnx
Models/Onnx/CrossEncoder/model_O1.onnx
Models/Onnx/CrossEncoder/model_O2.onnx
Models/Onnx/CrossEncoder/model_O3.onnx
Models/Onnx/CrossEncoder/model_O4.onnx
Models/Onnx/CrossEncoder/tokenizer.json

# Quantized Variants
Models/Onnx/CrossEncoder/*qint8*.onnx
Models/Onnx/CrossEncoder/*quint8*.onnx

# LLM Models (Removed from codebase - ignore if present)
Models/Onnx/phi-3-mini/
Models/Onnx/phi-3-medium/
Models/Onnx/phi-4-min/
Models/Onnx/gemma-4-e2b/

