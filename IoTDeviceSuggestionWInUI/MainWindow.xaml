<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="IoTDeviceSuggestionWInUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IoTDeviceSuggestionWInUI"
    xmlns:models="using:IoTDeviceSuggestionWInUI.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="IoT Device Recommender">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="🏠 IoT Device Recommender" 
                       FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Get personalized smart device suggestions for your home" 
                       FontSize="14" Foreground="Gray" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Input Section -->
        <StackPanel Grid.Row="1" Spacing="16">
            <!-- Room Selection -->
            <StackPanel Spacing="8">
                <TextBlock Text="Select Room" FontWeight="SemiBold" FontSize="14"/>
                <ComboBox x:Name="RoomComboBox" 
                          ItemsSource="{x:Bind ViewModel.AvailableRooms, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedRoom, Mode=TwoWay}"
                          PlaceholderText="Choose a room..."
                          Width="320" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- Region Selection -->
            <StackPanel Spacing="8">
                <TextBlock Text="Region" FontWeight="SemiBold" FontSize="14"/>
                <ComboBox x:Name="RegionComboBox" 
                          ItemsSource="{x:Bind ViewModel.AvailableRegions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedRegion, Mode=TwoWay}"
                          PlaceholderText="Select region..."
                          Width="200" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- Location (Latitude/Longitude) for Season Detection -->
            <StackPanel Spacing="8">
                <TextBlock Text="Location (for automatic season detection)" FontWeight="SemiBold" FontSize="14"/>
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Latitude -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Lat:" VerticalAlignment="Center" FontSize="13"/>
                        <TextBox Text="{x:Bind ViewModel.LatitudeText, Mode=TwoWay}"
                                 PlaceholderText="23.8103"
                                 Width="100"/>
                    </StackPanel>
                    
                    <!-- Longitude -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Long:" VerticalAlignment="Center" FontSize="13"/>
                        <TextBox Text="{x:Bind ViewModel.LongitudeText, Mode=TwoWay}"
                                 PlaceholderText="90.4125"
                                 Width="100"/>
                    </StackPanel>
                    
                    <!-- Detected Season Display -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Season:" VerticalAlignment="Center" FontSize="13" Foreground="Gray"/>
                        <TextBlock Text="{x:Bind ViewModel.DetectedSeason, Mode=OneWay}" 
                                   VerticalAlignment="Center" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Default: Dhaka, Bangladesh. Season is auto-detected from weather when you click Get Recommendations." 
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Owned Devices -->
            <StackPanel Spacing="8">
                <TextBlock Text="Owned Devices (comma-separated)" FontWeight="SemiBold" FontSize="14"/>
                <TextBox x:Name="DevicesTextBox"
                        Text="{x:Bind ViewModel.OwnedDevicesText, Mode=TwoWay}"
                        PlaceholderText="e.g., TV, Air Conditioner, Smart Speaker"
                        Width="480" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                <Button Content="🔍 Get Recommendations" 
                        Command="{x:Bind ViewModel.GetRecommendationsCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        MinWidth="180"/>
                <Button Content="Clear" 
                        Command="{x:Bind ViewModel.ClearInputCommand}"
                        MinWidth="80"/>
            </StackPanel>
        </StackPanel>

        <!-- Status -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                         Width="24" Height="24"
                         HorizontalAlignment="Left"/>
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                      FontSize="13" Foreground="Gray" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Results Section -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <ListView ItemsSource="{x:Bind ViewModel.Recommendations, Mode=OneWay}"
                     SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:RecommendationResult">
                        <Grid Padding="16" 
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                              BorderThickness="1" 
                              CornerRadius="8"
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Rank Badge -->
                            <Border Grid.Column="0" 
                                   Background="#0078D4" 
                                   CornerRadius="20" 
                                   Width="40" Height="40" 
                                   Margin="0,0,16,0"
                                   VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Rank}" 
                                          Foreground="White" 
                                          FontWeight="Bold" 
                                          FontSize="16"
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                            </Border>
                            
                            <!-- Device Info -->
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{x:Bind DeviceName}" 
                                          FontWeight="SemiBold" 
                                          FontSize="16"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Category}" 
                                              Foreground="Gray" 
                                              FontSize="13"/>
                                    <TextBlock Text="•" Foreground="Gray" FontSize="13"/>
                                    <TextBlock Text="{x:Bind Size}" 
                                              Foreground="Gray" 
                                              FontSize="13"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind Reasoning}" 
                                          TextWrapping="Wrap" 
                                          FontSize="13"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          Margin="0,4,0,0"/>
                                <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
                                    <TextBlock FontSize="12">
                                        <Run Text="Score: " Foreground="Gray"/>
                                        <Run Text="{x:Bind Score, Mode=OneWay}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock Text="|" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{x:Bind Rooms}" 
                                              FontSize="12" 
                                              Foreground="Gray"
                                              TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Window>